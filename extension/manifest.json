{
  "manifest_version": 3,
  "name": "Focus Tracker Blocker",
  "version": "0.1.0",
  "description": "Blokuje rozpraszajace strony podczas sesji Focus Tracker",
  "permissions": ["tabs", "storage", "scripting", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html"
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
